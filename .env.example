API_PORT=8787
CLIENT_ORIGIN=http://localhost:5173

# Preferred DeepSeek model configuration.
# Keep model provider keys on the server side only.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible aliases are still supported.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Legacy aliases are still supported.
# When all API keys are empty, the app uses local fallback feedback.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
