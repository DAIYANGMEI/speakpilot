API_PORT=8787
CLIENT_ORIGIN=http://localhost:5173

# Preferred OpenAI-compatible model configuration.
# Keep model provider keys on the server side only.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=chat-latest

# Legacy aliases are still supported.
# When all API keys are empty, the app uses local fallback feedback.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
